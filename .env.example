# AI & Search APIs
GEMINI_API_KEY=your_gemini_key
NEWS_API_KEY=your_newsapi_key

# Slack Bot Configuration
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_CHANNEL_ID=C0123456789

# Social Media (Buffer)
BUFFER_TOKEN=your_buffer_token

# Image Hosting (Required for Render Free tier)
IMGBB_API_KEY=your_imgbb_key

# Email/Newsletter Service
# Driver can be 'resend' (recommended) or 'smtp'
EMAIL_DRIVER=resend
RESEND_API_KEY=re_your_key
EMAIL_SENDER=onboarding@resend.dev
EMAIL_SENDER_NAME="AI News"

# Storage Configuration
# Use 'postgres' for Render (Persistent) or 'json' for local dev (Ephemeral)
STORAGE_DRIVER=json
DATABASE_URL=postgres://user:pass@host:port/dbname

# Deployment
BASE_PUBLIC_URL=https://your-app.onrender.com
PORT=8000
